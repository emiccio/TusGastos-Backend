# ─── Base de datos — Supabase ───────────────────────────────────
#
# En Supabase: Project Settings > Database > Connection string
# Usá el "Transaction pooler" (puerto 6543) para Render/servidores:
#
# postgresql://postgres.XXXX:PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true
#
# OJO: NO uses el puerto 5432 (direct connection) en Render — usá siempre
# el Transaction pooler (6543) o Session pooler (5432 via pooler).
# Prisma necesita ?pgbouncer=true al final cuando usás transaction pooler.
#
DATABASE_URL="postgresql://postgres.XXXX:PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Para migraciones locales (prisma migrate dev) usá la Direct connection:
# DATABASE_URL="postgresql://postgres:PASSWORD@db.XXXX.supabase.co:5432/postgres"

# ─── Servidor ──────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── JWT ───────────────────────────────────────────────────────
JWT_SECRET="cambia-esto-por-una-clave-secreta-larga-y-random"
JWT_EXPIRES_IN="30d"

# ─── OpenAI ────────────────────────────────────────────────────
OPENAI_API_KEY="sk-..."
OPENAI_MODEL="gpt-4o-mini"

# ─── WhatsApp (Meta Graph API) ─────────────────────────────────
WHATSAPP_TOKEN="EAAxxxxxxxx..."
WHATSAPP_PHONE_NUMBER_ID="1234567890"
WHATSAPP_VERIFY_TOKEN="tusgastos-webhook-secret-2024"

# ─── Frontend ──────────────────────────────────────────────────
FRONTEND_URL="http://localhost:3000"

# ─── LLM Provider ──────────────────────────────────────────────
# Opciones: "gemini" | "openai" | "auto"
# "auto" usa gemini primero (gratis), con fallback a openai si falla
LLM_PROVIDER=auto

# Google Gemini (gratis: 1500 req/día con gemini-1.5-flash)
# Obtené tu key en: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="AIza..."
GEMINI_MODEL="gemini-1.5-flash"
