# ─── Base de datos ─────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/tusgastos"

# ─── Servidor ──────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── JWT ───────────────────────────────────────────────────────
JWT_SECRET="cambia-esto-por-una-clave-secreta-larga-y-random"
JWT_EXPIRES_IN="30d"

# ─── OpenAI ────────────────────────────────────────────────────
OPENAI_API_KEY="sk-..."
OPENAI_MODEL="gpt-4o-mini"  # Más barato, suficiente para parsear mensajes

# ─── WhatsApp (Meta Graph API) ─────────────────────────────────
WHATSAPP_TOKEN="EAAxxxxxxxx..."          # Token de acceso permanente
WHATSAPP_PHONE_NUMBER_ID="1234567890"   # ID del número de WhatsApp Business
WHATSAPP_VERIFY_TOKEN="tusgastos-webhook-secret-2024"  # Lo inventás vos

# ─── Frontend ──────────────────────────────────────────────────
FRONTEND_URL="http://localhost:3000"     # En prod: https://tusgastos.vercel.app
