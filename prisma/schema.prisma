generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // En Render con Supabase: usar Transaction pooler (pgbouncer=true)
  url       = env("DATABASE_URL")
  // directUrl es la Direct connection — solo se usa para migraciones (prisma migrate)
  directUrl = env("DIRECT_URL")
}

model User {
  id              String            @id @default(cuid())
  phone           String            @unique
  name            String?
  plan            PlanType          @default(FREE)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  onboardingStep  String?           @default("WAITING_NAME") // null = onboarding completo, "WAITING_NAME" = esperando que dé su nombre

  transactions    Transaction[]     // transacciones creadas por este usuario
  sessions        Session[]
  memberships     HouseholdMember[]
  ownedHouseholds Household[]       @relation("HouseholdOwner")
  createdInvites  HouseholdInvite[] @relation("InviteCreator")
  usedInvites     HouseholdInvite[] @relation("InviteUser")

  @@map("users")
}

model Household {
  id           String            @id @default(cuid())
  name         String
  
  ownerId      String
  owner        User              @relation("HouseholdOwner", fields: [ownerId], references: [id])
  
  members      HouseholdMember[]
  transactions Transaction[]
  invites      HouseholdInvite[]
  categories   Category[]
  rules        CategoryRule[]
  
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  
  @@map("households")
}

model HouseholdMember {
  id          String    @id @default(cuid())
  userId      String
  householdId String
  role        String    @default("MEMBER") // ADMIN, MEMBER
  
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  joinedAt    DateTime  @default(now())

  @@unique([userId, householdId])
  @@map("household_members")
}

model HouseholdInvite {
  id          String    @id @default(cuid())
  token       String    @unique @default(cuid())
  householdId String
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  createdById String
  createdBy   User      @relation("InviteCreator", fields: [createdById], references: [id], onDelete: Cascade)
  usedById    String?
  usedBy      User?     @relation("InviteUser", fields: [usedById], references: [id])
  used        Boolean   @default(false)
  expiresAt   DateTime
  createdAt   DateTime  @default(now())

  @@index([token])
  @@map("household_invites")
}

model Transaction {
  id            String          @id @default(cuid())
  
  userId        String
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade) // quien la creó
  
  householdId   String
  household     Household       @relation(fields: [householdId], references: [id], onDelete: Cascade)
  
  type          TransactionType
  amount        Float
  category      String
  description   String?
  date          DateTime        @default(now())
  paymentMethod String          @default("cash") // cash, credit, debit, etc.
  rawMessage    String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([householdId])
  @@index([householdId, date])
  @@index([householdId, type])
  @@index([userId])
  @@map("transactions")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([token])
  @@map("sessions")
}

model WhatsappMessage {
  id          String   @id @default(cuid())
  messageId   String   @unique
  phone       String
  body        String
  direction   String
  processedAt DateTime @default(now())

  @@index([messageId])
  @@map("whatsapp_messages")
}

enum TransactionType {
  income
  expense
}

enum PlanType {
  FREE
  PREMIUM
}

model Category {
  id          String   @id @default(cuid())
  name        String
  icon        String?
  isCustom    Boolean  @default(true)
  
  householdId String
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  
  rules       CategoryRule[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@unique([householdId, name])
  @@map("categories")
}

model CategoryRule {
  id          String   @id @default(cuid())
  keyword     String
  
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  
  householdId String
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@unique([householdId, keyword])
  @@map("category_rules")
}
